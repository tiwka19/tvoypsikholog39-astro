---
interface Props {
  title: string;
}

const { title } = Astro.props;

import '@fontsource-variable/el-messiri';
import '@fontsource/raleway/400.css';
import '@fontsource/raleway/500.css';
import '@fontsource/raleway/700.css';

import Themes from 'astro-themes';

import Header from '../components/Header.astro';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <Themes />
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-white dark:bg-gray-900 transition-colors">
    <Header />
    <slot />
    <!-- <div>
      <button onclick="document.dispatchEvent(new CustomEvent('set-theme', { detail: 'light' }));">
        Light
      </button>
      <button onclick="document.dispatchEvent(new CustomEvent('set-theme', { detail: 'dark' }));">
        Dark
      </button>
      <button onclick="document.dispatchEvent(new CustomEvent('set-theme', { detail: null }))">
        Clear theme
      </button>
    </div> -->
  </body>
</html>
